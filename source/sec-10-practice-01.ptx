<?xml version="1.0" encoding="UTF-8"?>
<section xml:id="sec-practice-quiz-1">
  <title>Practice Quiz 1</title>

  <p>Only a writing utensil, note card, and a calculator may be used for this quiz.
  No phones or other web-enabled devices permitted.
  You must show all work to ensure full credit.</p>

  <exercises>

    <exercise xml:id="ex-pq1-1">
      <statement>
        <p>Describe in writing characteristics of linear change.</p>
      </statement>
    </exercise>

    <exercise xml:id="ex-pq1-2">
      <statement>
        <p>Consider the linear equation <m>y = 2x - 1</m>.
        Fill in the missing values in the table corresponding to this equation.</p>
        <tabular halign="center" top="minor" bottom="minor" left="minor" right="minor">
          <row bottom="minor">
            <cell><m>x</m></cell>
            <cell><m>-3</m></cell>
            <cell><m>0</m></cell>
            <cell><m>\phantom{xxx}</m></cell>
          </row>
          <row>
            <cell><m>y</m></cell>
            <cell><m>\phantom{xxx}</m></cell>
            <cell><m>\phantom{xxx}</m></cell>
            <cell><m>8</m></cell>
          </row>
        </tabular>
      </statement>
    </exercise>

    <exercise xml:id="ex-pq1-3">
      <introduction>
        <p>For each of the following tables, determine if the change could be linear or not.
        If the data could be linear, find an equation for the line.</p>
        </introduction>
      <task xml:id="ex-pq1-3a">
        <statement>
          <tabular halign="center" top="minor" bottom="minor" left="minor" right="minor">
            <row bottom="minor">
              <cell><m>x</m></cell>
              <cell><m>1</m></cell>
              <cell><m>2</m></cell>
              <cell><m>3</m></cell>
              <cell><m>4</m></cell>
              <cell><m>5</m></cell>
            </row>
            <row>
              <cell><m>y</m></cell>
              <cell><m>1</m></cell>
              <cell><m>4</m></cell>
              <cell><m>6</m></cell>
              <cell><m>8</m></cell>
              <cell><m>11</m></cell>
            </row>
          </tabular>
        </statement>
      </task>
      <task xml:id="ex-pq1-3b">
        <statement>
          <tabular halign="center" top="minor" bottom="minor" left="minor" right="minor">
            <row bottom="minor">
              <cell><m>x</m></cell>
              <cell><m>2</m></cell>
              <cell><m>4</m></cell>
              <cell><m>6</m></cell>
              <cell><m>8</m></cell>
              <cell><m>10</m></cell>
            </row>
            <row>
              <cell><m>y</m></cell>
              <cell><m>5</m></cell>
              <cell><m>4.5</m></cell>
              <cell><m>4</m></cell>
              <cell><m>3.5</m></cell>
              <cell><m>3</m></cell>
            </row>
          </tabular>
        </statement>
      </task>
      <task xml:id="ex-pq1-3c">
        <statement>
          <tabular halign="center" top="minor" bottom="minor" left="minor" right="minor">
            <row bottom="minor">
              <cell><m>x</m></cell>
              <cell><m>1</m></cell>
              <cell><m>3</m></cell>
              <cell><m>4</m></cell>
              <cell><m>8</m></cell>
              <cell><m>10</m></cell>
            </row>
            <row>
              <cell><m>y</m></cell>
              <cell><m>100</m></cell>
              <cell><m>80</m></cell>
              <cell><m>70</m></cell>
              <cell><m>30</m></cell>
              <cell><m>10</m></cell>
            </row>
          </tabular>
        </statement>
      </task>
    </exercise>

    <exercise xml:id="ex-pq1-4">
      <statement>
        <p>Find an equation of a line with slope <m>-\dfrac{1}{2}</m>
        and <m>y</m>-intercept <m>\dfrac{11}{3}</m>.</p>
      </statement>
      <solution>
    <p>Using slope-intercept form <m>y = mx + b</m>, we get
    <md>y = -\frac{1}{2}x + \frac{11}{3}.</md></p>
  </solution>
    </exercise>

    <exercise xml:id="ex-pq1-5">
      <statement>
        <p>Find an equation of a line through <m>(-1, 3)</m> and <m>(2, 9)</m>.</p>
      </statement>
    </exercise>

    <exercise xml:id="ex-pq1-6">
      <introduction>
        <p>For each of the following <em>linear</em> equations, find the <m>x</m> and
        <m>y</m> intercepts and sketch the graph.</p>
        </introduction>
      <task xml:id="ex-pq1-6a">
        <statement>
          <p><m>2x - 5y = 10</m></p>
        </statement>
      </task>
      <task xml:id="ex-pq1-6b">
        <statement>
          <p><m>7x + 4y = 3</m></p>
        </statement>
      </task>
    </exercise>

  </exercises>

</section>